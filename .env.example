# Copia este archivo a ".env" y coloca tu clave de Google AI Studio (Gemini).
# Consíguela en https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=tu_clave_aqui
VITE_GEMINI_MODEL=gemini-2.5-flash

# Voz natural (TTS). Voces: Aoede, Kore, Leda, Puck, Charon, Fenrir, Zephyr...
VITE_GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
VITE_GEMINI_VOICE=Aoede
